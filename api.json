{
  "openapi": "3.0.3",
  "info": {
    "title": "Synology DSM Login Web API",
    "description": "群晖DSM登录核心Web API，基于DSM 7.0+开发，包含API信息查询、账号登录、登出、CSRF Token获取等能力，所有请求基于HTTP/HTTPS，统一入口为entry.cgi",
    "version": "1.0.0",
    "contact": {
      "name": "Synology Inc.",
      "description": "Official Guide: DSM Login Web API Guide (2023-04-19)"
    }
  },
  "servers": [
    {
      "url": "https://{nasAddress}:{port}/webapi",
      "description": "群晖NAS DSM API服务根地址",
      "variables": {
        "nasAddress": {
          "description": "群晖NAS的IP地址或域名",
          "example": "192.168.1.100",
          "type": "string"
        },
        "port": {
          "description": "DSM服务端口（HTTP:5000，HTTPS:5001，自定义端口请替换）",
          "example": "5001",
          "type": "string"
        }
      }
    }
  ],
  "paths": {
    "/entry.cgi": {
      "get": {
        "summary": "DSM基础API统一请求入口",
        "description": "SYNO.API.Info/SYNO.API.Auth的所有方法均通过该接口请求，通过api/version/method参数区分具体操作，支持GET/POST",
        "parameters": [
          {
            "name": "api",
            "in": "query",
            "required": true,
            "description": "要请求的API名称",
            "schema": {
              "type": "string",
              "enum": ["SYNO.API.Info", "SYNO.API.Auth"]
            },
            "example": "SYNO.API.Info"
          },
          {
            "name": "version",
            "in": "query",
            "required": true,
            "description": "API版本号，不同API支持版本范围不同（Info:1；Auth:3-7，推荐6）",
            "schema": {
              "type": "integer"
            },
            "example": 1
          },
          {
            "name": "method",
            "in": "query",
            "required": true,
            "description": "API对应的操作方法",
            "schema": {
              "type": "string",
              "enum": ["query", "login", "logout", "token"]
            },
            "example": "query"
          },
          {
            "name": "query",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Info的query方法使用，指定查询的API名（逗号分隔），all表示查询所有",
            "schema": {
              "type": "string"
            },
            "example": "SYNO.API.Auth,SYNO.FileStation.List"
          },
          {
            "name": "account",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，DSM登录账号",
            "schema": {
              "type": "string"
            },
            "example": "admin"
          },
          {
            "name": "passwd",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，DSM登录密码",
            "schema": {
              "type": "string"
            },
            "example": "your-dsm-password"
          },
          {
            "name": "session",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，DSM应用会话名称（可选）",
            "schema": {
              "type": "string"
            },
            "example": "FileStation"
          },
          {
            "name": "otp_code",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，二次验证OTP码（开启2FA时必填）",
            "schema": {
              "type": "string"
            },
            "example": "123456"
          },
          {
            "name": "enable_syno_token",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用（6+版本），是否获取CSRF Token",
            "schema": {
              "type": "string",
              "enum": ["yes", "no"]
            },
            "example": "yes"
          },
          {
            "name": "enable_device_token",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用（6+版本），是否开启设备免2FA验证",
            "schema": {
              "type": "string",
              "enum": ["yes", "no"]
            },
            "example": "yes"
          },
          {
            "name": "device_name",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，设备名称（开启设备免2FA时必填）",
            "schema": {
              "type": "string"
            },
            "example": "MyWindowsPC"
          },
          {
            "name": "device_id",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，设备ID（免2FA验证时传入）",
            "schema": {
              "type": "string"
            },
            "example": "8nC0nhJjgiE1XTqM6aKOS6-K1IIs6r-vHNpH72eUe-XNSWs9OtF5c48EjaqXygEgvnEoARJJDWskZ656CVWl2w"
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "仅SYNO.API.Auth的login方法使用，会话存储格式（cookie/sid）",
            "schema": {
              "type": "string",
              "enum": ["cookie", "sid"]
            },
            "example": "cookie"
          },
          {
            "name": "_sid",
            "in": "query",
            "required": false,
            "description": "会话ID，未使用cookie时，所有后续请求需携带",
            "schema": {
              "type": "string"
            },
            "example": "K5LlN6r-zkpxg61He2eSS2zIRrPf1aG7L7eGBjAsU8gd7gbtDEuYCtdOH1Y5Kgr-F3_rl86kYyzCzSxzwHGH90"
          },
          {
            "name": "SynoToken",
            "in": "query",
            "required": false,
            "description": "CSRF Token，服务端开启CSRF防护时，所有请求需携带",
            "schema": {
              "type": "string"
            },
            "example": "03yhfxW4syRQw"
          }
        ],
        "responses": {
          "200": {
            "description": "请求成功，返回JSON格式数据，根据操作方法返回不同结构",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/SYNO_API_Info_Response"
                    },
                    {
                      "$ref": "#/components/schemas/SYNO_API_Auth_Login_Response"
                    },
                    {
                      "$ref": "#/components/schemas/SYNO_API_Auth_Token_Response"
                    },
                    {
                      "$ref": "#/components/schemas/SYNO_API_Auth_Logout_Response"
                    }
                  ]
                },
                "examples": {
                  "API信息查询成功": {
                    "value": {
                      "success": true,
                      "data": {
                        "SYNO.API.Auth": {
                          "path": "entry.cgi",
                          "minVersion": 1,
                          "maxVersion": 7
                        },
                        "SYNO.FileStation.List": {
                          "path": "entry.cgi",
                          "requestFormat": "JSON",
                          "minVersion": 1,
                          "maxVersion": 2
                        }
                      }
                    }
                  },
                  "登录成功（带Token）": {
                    "value": {
                      "success": true,
                      "data": {
                        "did": "8nC0nhJjgiE1XTqM6aKOS6-K1IIs6r-vHNpH72eUe-XNSWs9OtF5c48EjaqXygEgvnEoARJJDWskZ656CVWl2w",
                        "is_portal_port": false,
                        "sid": "K5LlN6r-zkpxg61He2eSS2zIRrPf1aG7L7eGBjAsU8gd7gbtDEuYCtdOH1Y5Kgr-F3_rl86kYyzCzSxzwHGH90",
                        "synotoken": "03yhfxW4syRQw"
                      }
                    }
                  },
                  "获取CSRF Token成功": {
                    "value": {
                      "success": true,
                      "data": {
                        "is_portal_port": false,
                        "synotoken": "03yhfxW4syRQw"
                      }
                    }
                  },
                  "登出成功": {
                    "value": {
                      "success": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求失败，返回错误码（通用错误码100-150，API专属错误码400+）",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error_Response"
                },
                "examples": {
                  "账号密码错误": {
                    "value": {
                      "success": false,
                      "error": {
                        "code": 400
                      }
                    }
                  },
                  "缺少核心参数": {
                    "value": {
                      "success": false,
                      "error": {
                        "code": 101
                      }
                    }
                  },
                  "2FA验证失败": {
                    "value": {
                      "success": false,
                      "error": {
                        "code": 404
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error_Response": {
        "type": "object",
        "required": ["success", "error"],
        "properties": {
          "success": {
            "type": "boolean",
            "description": "请求是否成功，失败为false",
            "example": false
          },
          "error": {
            "type": "object",
            "required": ["code"],
            "properties": {
              "code": {
                "type": "integer",
                "description": "错误码：通用100-150，API专属400+",
                "example": 400
              },
              "errors": {
                "type": "array",
                "description": "详细错误信息（可选，多文件操作时返回）",
                "items": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 408
                    },
                    "path": {
                      "type": "string",
                      "description": "错误关联路径（可选）",
                      "example": "/test/:"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SYNO_API_Info_Response": {
        "type": "object",
        "required": ["success", "data"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "description": "键为API名称，值为该API的详细元信息",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "description": "API的请求路径",
                  "example": "entry.cgi"
                },
                "minVersion": {
                  "type": "integer",
                  "description": "API最小支持版本",
                  "example": 1
                },
                "maxVersion": {
                  "type": "integer",
                  "description": "API最大支持版本",
                  "example": 7
                },
                "requestFormat": {
                  "type": "string",
                  "description": "请求参数格式（可选，JSON表示需JSON编码）",
                  "example": "JSON"
                }
              }
            }
          }
        }
      },
      "SYNO_API_Auth_Login_Response": {
        "type": "object",
        "required": ["success", "data"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "sid": {
                "type": "string",
                "description": "授权会话ID，未使用cookie时后续请求需携带",
                "example": "K5LlN6r-zkpxg61He2eSS2zIRrPf1aG7L7eGBjAsU8gd7gbtDEuYCtdOH1Y5Kgr-F3_rl86kYyzCzSxzwHGH90"
              },
              "did": {
                "type": "string",
                "description": "设备ID，用于设备免2FA验证",
                "example": "8nC0nhJjgiE1XTqM6aKOS6-K1IIs6r-vHNpH72eUe-XNSWs9OtF5c48EjaqXygEgvnEoARJJDWskZ656CVWl2w"
              },
              "is_portal_port": {
                "type": "boolean",
                "description": "是否为门户端口（无实际业务意义）",
                "example": false
              },
              "synotoken": {
                "type": "string",
                "description": "CSRF Token，开启CSRF防护时后续请求需携带（可选）",
                "example": "03yhfxW4syRQw"
              }
            }
          }
        }
      },
      "SYNO_API_Auth_Token_Response": {
        "type": "object",
        "required": ["success", "data"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "is_portal_port": {
                "type": "boolean",
                "example": false
              },
              "synotoken": {
                "type": "string",
                "description": "CSRF Token，用于防跨站请求伪造",
                "example": "03yhfxW4syRQw"
              }
            }
          }
        }
      },
      "SYNO_API_Auth_Logout_Response": {
        "type": "object",
        "required": ["success"],
        "properties": {
          "success": {
            "type": "boolean",
            "description": "登出是否成功，成功为true",
            "example": true
          }
        }
      }
    }
  }
}